        {
          "requirement_id": "REQ-FR-041",
          "step_number": 5,
          "step_description": "Inspect queue columns and row values.",
          "expected_output": "TX-ID, Side, Ticker, Qty, Price, Total, Action columns are visible with both AAPL rows.",
          "test_data": "expectedColumns=TX-ID|Side|Ticker|Qty|Price|Total|Action"
