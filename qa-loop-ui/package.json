{
  "name": "qa-loop-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun --watch src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "bun run typecheck && vite build",
    "start": "bun src/server/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.126",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.468.0",
    "vite": "^8.0.10",
    "typescript": "^6.0.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
