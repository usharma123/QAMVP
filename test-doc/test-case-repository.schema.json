{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Detailed test-case repository spec",
  "type": "object",
  "required": ["cases"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string" },
    "document_id": { "type": "string" },
    "version": { "type": "string" },
    "status": { "type": "string" },
    "source_workbook": { "type": "string" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["test_case_id", "title", "objective", "steps"],
        "additionalProperties": false,
        "properties": {
          "test_case_id": { "type": "string", "pattern": "^TC-[A-Za-z0-9-]+$" },
          "title": { "type": "string", "minLength": 1 },
          "objective": { "type": "string", "minLength": 1 },
          "priority": { "type": "string" },
          "suite": { "type": "string" },
          "tags": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["requirement_id", "step_number", "step_description"],
              "additionalProperties": false,
              "properties": {
                "requirement_id": { "type": "string", "minLength": 1 },
                "step_number": { "type": "integer", "minimum": 1 },
                "step_description": { "type": "string", "minLength": 1 },
                "expected_output": { "type": "string" },
                "test_data": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
