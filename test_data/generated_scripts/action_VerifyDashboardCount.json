{
  "name": "VerifyDashboardCount",
  "description": "Navigates to the Dashboard page (NOT Trade List) and asserts the Total Trades label equals expectedCount. Only counts approved trades.",
  "steps": [
    {
      "action": "CLICK",
      "locator": "$trading-menu-trigger",
      "test_input": "",
      "output": ""
    },
    {
      "action": "WAIT_VISIBLE",
      "locator": "$nav-dashboard",
      "test_input": "5",
      "output": ""
    },
    {
      "action": "CLICK",
      "locator": "$nav-dashboard",
      "test_input": "",
      "output": ""
    },
    {
      "action": "WAIT_VISIBLE",
      "locator": "$dashboard-page",
      "test_input": "10",
      "output": ""
    },
    {
      "action": "WAIT_HIDDEN",
      "locator": "$dashboard-loading",
      "test_input": "10",
      "output": ""
    },
    {
      "action": "READ_TEXT",
      "locator": "$dashboard-trade-count",
      "test_input": "",
      "output": "dashboardCount"
    },
    {
      "action": "ASSERT_TEXT",
      "locator": "$dashboard-trade-count",
      "test_input": "Total Trades: {{expectedCount}}",
      "output": ""
    }
  ]
}