      "test_case_id": "TC-001",
      "title": "Maker submits BUY, checker approves, dashboard reflects one approved trade",
      "objective": "Validate the core maker-checker happy path from login through approval and approved-only dashboard count.",
      "priority": "P1",
      "suite": "S-1 Smoke",
      "tags": [
        "@smoke",
        "@maker",
        "@checker",
        "@approval",
        "@dashboard"
      ],
      "steps": [
        {
          "requirement_id": "REQ-FR-002",
          "step_number": 1,
          "step_description": "Login as maker using documented credentials.",
          "expected_output": "Dashboard page loads and navbar shows admin (maker).",
          "test_data": "username=admin,password=admin"
        },
        {
          "requirement_id": "REQ-FR-012",
          "step_number": 2,
          "step_description": "Open Trading menu and navigate to New Trade.",
          "expected_output": "New Trade form is visible.",
          "test_data": "target=nav-new-trade"
        },
        {
          "requirement_id": "REQ-FR-030",
          "step_number": 3,
          "step_description": "Select BUY, Technology, AAPL, Cash, quantity 100, Day Order.",
          "expected_output": "All required trade form fields are populated.",
          "test_data": "side=BUY,sector=Technology,ticker=AAPL,accountType=Cash,quantity=100,timeInForce=Day Order"
        },
        {
          "requirement_id": "REQ-FR-031",
          "step_number": 4,
          "step_description": "Wait for ticker price and total value to calculate.",
          "expected_output": "Current Price is 178.50 and Total Value is 17850.00.",
          "test_data": "ticker=AAPL,expectedPrice=178.50,expectedTotal=17850.00"
        },
        {
          "requirement_id": "REQ-FR-033",
          "step_number": 5,
          "step_description": "Submit the order.",
          "expected_output": "Success toast confirms Order TX-1001 and workflow moves toward approval queue.",
          "test_data": "expectedTxId=TX-1001"
        },
        {
          "requirement_id": "REQ-FR-040",
          "step_number": 6,
          "step_description": "Open Approval Queue as maker before approval.",
          "expected_output": "Queue shows Pending: 1 and includes BUY AAPL quantity 100.",
          "test_data": "expectedPending=1,ticker=AAPL,side=BUY,quantity=100"
        },
        {
          "requirement_id": "REQ-FR-014",
          "step_number": 7,
          "step_description": "Logout maker.",
          "expected_output": "Login page is visible and maker session is cleared.",
          "test_data": ""
        },
        {
          "requirement_id": "REQ-FR-003",
          "step_number": 8,
          "step_description": "Login as checker.",
          "expected_output": "Dashboard page loads and navbar shows checker (checker).",
          "test_data": "username=checker,password=chscker@123"
        },
        {
          "requirement_id": "REQ-FR-043",
          "step_number": 9,
          "step_description": "Open Approval Queue and approve the AAPL BUY row.",
          "expected_output": "Approve action completes for TX-1001.",
          "test_data": "ticker=AAPL,side=BUY"
        },
        {
          "requirement_id": "REQ-FR-044",
          "step_number": 10,
          "step_description": "Observe approval feedback.",
          "expected_output": "Toast displays Trade TX-1001 approved.",
          "test_data": "expectedToast=Trade TX-1001 approved"
        },
        {
          "requirement_id": "REQ-FR-045",
          "step_number": 11,
          "step_description": "Refresh or revisit Approval Queue.",
          "expected_output": "Queue shows Pending: 0 and the approved row is removed.",
          "test_data": "expectedPending=0"
        },
        {
          "requirement_id": "REQ-FR-020",
          "step_number": 12,
          "step_description": "Navigate to Dashboard.",
          "expected_output": "Dashboard includes the approved AAPL trade and excludes pending-only rows.",
          "test_data": "ticker=AAPL"
        },
        {
          "requirement_id": "REQ-FR-022",
          "step_number": 13,
          "step_description": "Verify Dashboard total count.",
          "expected_output": "Total Trades: 1 is displayed.",
          "test_data": "expectedCount=1"
        }
      ]
    },
